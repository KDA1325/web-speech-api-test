# Production-like safe mode: browser calls your backend proxy.
# This is a browser-safe backend base URL. This is not an OpenAI/LLM API key.
VITE_COMMAND_API_URL=https://your-command-api.example.com

# Local experiment only:
# If true, the browser calls OpenAI directly. The key will be visible in DevTools.
VITE_ALLOW_BROWSER_LLM_DIRECT=false
VITE_OPENAI_API_KEY=
VITE_OPENAI_MODEL=gpt-4.1-mini

# Never use browser direct mode for deployment/shared demos.
# Put production secrets only in the server runtime environment.
